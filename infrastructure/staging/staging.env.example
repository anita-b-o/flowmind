# Public, non-secret deployment identity.
STAGING_WEB_HOST=staging.example.com
STAGING_API_HOST=api.staging.example.com
PUBLIC_APP_URL=https://staging.example.com
PUBLIC_API_URL=https://api.staging.example.com
CORS_ORIGIN=https://staging.example.com
ACME_EMAIL=release-ops@example.com

# Every image value must include @sha256:<digest>.
FLOWMIND_API_IMAGE=ghcr.io/anita-b-o/flowmind-api@sha256:replace
FLOWMIND_WORKER_IMAGE=ghcr.io/anita-b-o/flowmind-worker@sha256:replace
FLOWMIND_WEB_IMAGE=ghcr.io/anita-b-o/flowmind-web@sha256:replace
FLOWMIND_AI_IMAGE=ghcr.io/anita-b-o/flowmind-ai-service@sha256:replace
FLOWMIND_MIGRATE_IMAGE=ghcr.io/anita-b-o/flowmind-migrate@sha256:replace
CADDY_IMAGE=caddy:2.10.0-alpine@sha256:ae4458638da8e1a91aafffb231c5f8778e964bca650c8a8cb23a7e8ac557aa3c
PROMETHEUS_IMAGE=prom/prometheus:v3.5.0@sha256:63805ebb8d2b3920190daf1cb14a60871b16fd38bed42b857a3182bc621f4996
ALERTMANAGER_IMAGE=prom/alertmanager:v0.28.1@sha256:27c475db5fb156cab31d5c18a4251ac7ed567746a2483ff264516437a39b15ba
POSTGRES_BACKUP_IMAGE=postgres:16-alpine@sha256:57c72fd2a128e416c7fcc499958864df5301e940bca0a56f58fddf30ffc07777

# Root-only host paths; never commit the real files.
METRICS_API_KEY_FILE=/opt/flowmind/secrets/metrics_api_key
ALERTMANAGER_CONFIG_PATH=/opt/flowmind/config/alertmanager.yml

# Secrets below belong in /opt/flowmind/config/staging.env, mode 0600.
DATABASE_URL=postgresql://staging-user:replace@staging-db.invalid:5432/flowmind_staging?sslmode=require
REDIS_URL=rediss://staging-user:replace@staging-redis.invalid:6380/0
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
SESSION_IP_HASH_PEPPER=replace-with-at-least-32-random-characters
SECRET_ENCRYPTION_KEY=replace-with-at-least-32-random-characters
CONNECTION_ENCRYPTION_KEY=base64:replace-with-32-random-bytes
AI_SERVICE_API_KEY=replace-with-at-least-32-random-characters
WEBHOOK_TOKEN_PEPPER=replace-with-at-least-32-random-characters
METRICS_API_KEY=replace-with-at-least-16-random-characters
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
MAIL_HOST=staging-smtp.invalid
MAIL_PORT=1025
