FROM python:3.12-slim AS runtime
ARG BUILD_VERSION=dev
ARG BUILD_REVISION=unknown
ARG BUILD_CREATED=unknown
ENV PYTHONUNBUFFERED=1
WORKDIR /app
COPY apps/ai-service/pyproject.toml ./pyproject.toml
COPY apps/ai-service/app ./app
RUN pip install --no-cache-dir .
RUN useradd --create-home --uid 10001 flowmind && chown -R flowmind:flowmind /app
LABEL org.opencontainers.image.title="FlowMind AI Service" \
      org.opencontainers.image.source="https://github.com/anita-b-o/flowmind" \
      org.opencontainers.image.version="${BUILD_VERSION}" \
      org.opencontainers.image.revision="${BUILD_REVISION}" \
      org.opencontainers.image.created="${BUILD_CREATED}"
USER flowmind
EXPOSE 8000
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--no-access-log"]
