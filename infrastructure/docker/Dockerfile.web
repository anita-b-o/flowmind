FROM node:22-bookworm-slim AS build
ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
RUN corepack enable
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile && pnpm --filter @automation/web... build

FROM node:22-bookworm-slim AS runtime
ARG BUILD_VERSION=dev
ARG BUILD_REVISION=unknown
ARG BUILD_CREATED=unknown
ENV NODE_ENV=production
WORKDIR /app
COPY --from=build --chown=node:node /app /app
COPY infrastructure/docker/web-entrypoint.sh /usr/local/bin/flowmind-web-entrypoint
RUN chmod 0755 /usr/local/bin/flowmind-web-entrypoint
LABEL org.opencontainers.image.title="FlowMind Web" \
      org.opencontainers.image.source="https://github.com/anita-b-o/flowmind" \
      org.opencontainers.image.version="${BUILD_VERSION}" \
      org.opencontainers.image.revision="${BUILD_REVISION}" \
      org.opencontainers.image.created="${BUILD_CREATED}"
USER node
EXPOSE 3000
ENTRYPOINT ["flowmind-web-entrypoint"]
CMD ["corepack", "pnpm", "--filter", "@automation/web", "start"]
