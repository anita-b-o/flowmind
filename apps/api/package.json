{
  "name": "@automation/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests --runInBand",
    "test:unit": "jest --passWithNoTests --runInBand --testRegex 'src/.*\\.spec\\.ts$'",
    "test:integration": "flock -x /tmp/flowmind-api-db-tests.lock jest --passWithNoTests --runInBand --testRegex 'test/.*\\.spec\\.ts$'",
    "test:e2e": "flock -x /tmp/flowmind-api-db-tests.lock jest --passWithNoTests --runInBand --testRegex '.*\\.e2e-spec\\.ts$'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@automation/config": "workspace:*",
    "@automation/expression-engine": "workspace:*",
    "@automation/observability": "workspace:*",
    "@automation/shared-types": "workspace:*",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.1.0",
    "@prisma/client": "^6.1.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^4.9.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "luxon": "^3.7.2",
    "nanoid": "^5.0.9",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
