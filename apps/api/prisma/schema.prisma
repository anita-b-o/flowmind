generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum OrganizationRole {
  owner
  admin
  editor
  viewer
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ExecutionStatus {
  PENDING
  QUEUED
  RUNNING
  RETRYING
  COMPLETED
  FAILED
  CANCELLED
}

enum StepExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  RETRYING
}

enum ExecutionMode {
  REAL
  TEST
}

enum ExecutionReplayMode {
  FULL_REPLAY
  RETRY_FROM_FAILURE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  CANCELLED
}

enum ApprovalDecision {
  APPROVED
  REJECTED
}

enum TestExternalMode {
  mock
  real
}

enum IdempotencyStatus {
  STARTED
  PROCESSING
  ENQUEUED
  COMPLETED
  FAILED
}

enum InternalEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  DEAD
}

enum InternalEventDeliveryStatus {
  PENDING
  MATERIALIZED
  SKIPPED
}

enum ConnectionType {
  smtp
  http_api_key
  oauth_future
}

enum ConnectionStatus {
  ACTIVE
  DISABLED
  REVOKED
  DELETED
}

enum SecretStatus {
  ACTIVE
  REVOKED
}

enum NotificationChannel {
  EMAIL
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD_LETTER
  CANCELLED
}

enum NotificationErrorCategory {
  TRANSIENT
  INVALID_RECIPIENT
  TEMPLATE
  CONFIGURATION
  PROVIDER_REJECTED
  UNKNOWN
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  memberships               OrganizationMember[]
  workflows                 Workflow[]            @relation("WorkflowCreatedBy")
  versions                  WorkflowVersion[]     @relation("WorkflowVersionCreatedBy")
  sessions                  RefreshTokenSession[]
  requestedExecutionRetries Execution[]           @relation("ExecutionRetryRequestedBy")
  startedExecutions         Execution[]           @relation("ExecutionStartedBy")
  requestedExecutionCancels Execution[]           @relation("ExecutionCancelRequestedBy")
  workflowTestRuns          WorkflowTestRun[]      @relation("WorkflowTestRunCreatedBy")
  decidedApprovals          ApprovalRequest[]

  @@map("users")
}

model RefreshTokenSession {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  tokenHash           String    @map("token_hash")
  tokenFamily         String    @map("token_family")
  revokedAt           DateTime? @map("revoked_at")
  replacedBySessionId String?   @unique @map("replaced_by_session_id")
  expiresAt           DateTime  @map("expires_at")
  lastUsedAt          DateTime  @default(now()) @map("last_used_at")
  userAgent           String?   @map("user_agent")
  ipHash              String?   @map("ip_hash")
  createdAt           DateTime  @default(now()) @map("created_at")

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession RefreshTokenSession?  @relation("RefreshTokenSessionReplacement", fields: [replacedBySessionId], references: [id])
  replacesSessions  RefreshTokenSession[] @relation("RefreshTokenSessionReplacement")

  @@index([userId])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token_sessions")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members              OrganizationMember[]
  workflows            Workflow[]
  workflowVersions     WorkflowVersion[]
  workflowSteps        WorkflowStep[]
  triggers             Trigger[]
  webhookReplayNonces  WebhookReplayNonce[]
  executions           Execution[]
  stepExecutions       StepExecution[]
  stepExecutionAttempts StepExecutionAttempt[]
  recoveryStepReuses ExecutionStepReuse[]
  deadLetterExecutions DeadLetterExecution[]
  connections          Connection[]
  secrets              Secret[]
  webhookEvents        WebhookEvent[]
  workflowTestRuns     WorkflowTestRun[]
  auditLogs            AuditLog[]
  idempotencyKeys      IdempotencyKey[]
  internalRecords      InternalRecord[]
  organizationVariables OrganizationVariable[]
  workflowVariables    WorkflowVariable[]
  dataStores           DataStore[]
  dataStoreRecords     DataStoreRecord[]
  approvalRequests     ApprovalRequest[]
  internalEvents       InternalEvent[]
  internalEventChains  InternalEventChain[]
  internalEventDeliveries InternalEventDelivery[]
  notificationRules     NotificationRule[]
  notificationRequests  NotificationRequest[]
  notificationDeliveries NotificationDelivery[]

  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  role           OrganizationRole
  status         MemberStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Workflow {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  name            String
  description     String?
  status          WorkflowStatus @default(DRAFT)
  activeVersionId String?        @unique @map("active_version_id")
  createdByUserId String         @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("WorkflowCreatedBy", fields: [createdByUserId], references: [id])
  versions             WorkflowVersion[]     @relation("WorkflowVersions")
  activeVersion        WorkflowVersion?      @relation("ActiveWorkflowVersion", fields: [activeVersionId], references: [id])
  triggers             Trigger[]
  executions           Execution[]
  testRuns             WorkflowTestRun[]
  internalRecords      InternalRecord[]
  deadLetterExecutions DeadLetterExecution[]
  variables            WorkflowVariable[]
  approvalRequests     ApprovalRequest[]

  @@index([organizationId, status])
  @@map("workflows")
}

model WorkflowVersion {
  id              String                @id @default(uuid())
  organizationId  String                @map("organization_id")
  workflowId      String                @map("workflow_id")
  versionNumber   Int                   @map("version_number")
  status          WorkflowVersionStatus @default(DRAFT)
  definitionJson  Json                  @map("definition_json")
  createdByUserId String                @map("created_by_user_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  activatedAt     DateTime?             @map("activated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow             Workflow              @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  activeForWorkflow    Workflow?             @relation("ActiveWorkflowVersion")
  createdBy            User                  @relation("WorkflowVersionCreatedBy", fields: [createdByUserId], references: [id])
  steps                WorkflowStep[]
  executions           Execution[]
  testRuns             WorkflowTestRun[]
  internalRecords      InternalRecord[]
  deadLetterExecutions DeadLetterExecution[]
  approvalRequests     ApprovalRequest[]

  @@unique([workflowId, versionNumber])
  @@index([organizationId, workflowId])
  @@map("workflow_versions")
}

model WorkflowStep {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  workflowVersionId String   @map("workflow_version_id")
  key               String
  name              String
  type              String
  position          Int
  configJson        Json     @map("config_json")
  retryPolicyJson   Json?    @map("retry_policy_json")
  timeoutSeconds    Int?     @map("timeout_seconds")
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  stepExecutions  StepExecution[]

  @@unique([workflowVersionId, key])
  @@index([organizationId, workflowVersionId])
  @@map("workflow_steps")
}

model Trigger {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  workflowId      String    @map("workflow_id")
  type            String
  eventType       String?   @map("event_type")
  httpMethod      String    @default("POST") @map("http_method")
  tokenHash       String?   @map("token_hash")
  tokenPreview    String?   @map("token_preview")
  configJson      Json      @map("config_json")
  enabled         Boolean   @default(true)
  paused          Boolean   @default(false)
  cron            String?
  timezone        String?
  executionPolicy String    @default("skip_if_running") @map("execution_policy")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  rotatedAt       DateTime? @map("rotated_at")
  deletedAt       DateTime? @map("deleted_at")
  lastReceivedAt  DateTime? @map("last_received_at")
  lastExecutionId String?   @map("last_execution_id")
  lastRunAt       DateTime? @map("last_run_at")
  nextRunAt       DateTime? @map("next_run_at")

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow            Workflow             @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lastExecution       Execution?           @relation("TriggerLastExecution", fields: [lastExecutionId], references: [id], onDelete: SetNull)
  scheduledExecutions Execution[]           @relation("ScheduledTriggerExecutions")
  webhookEvents       WebhookEvent[]
  webhookReplayNonces WebhookReplayNonce[]
  internalEventDeliveries InternalEventDelivery[]

  @@index([id, enabled, deletedAt])
  @@index([tokenHash])
  @@index([organizationId, workflowId])
  @@index([workflowId, enabled])
  @@index([type, enabled, paused, deletedAt, nextRunAt])
  @@index([organizationId, type, eventType, enabled, deletedAt])
  @@map("triggers")
}

model Execution {
  id                     String          @id @default(uuid())
  organizationId         String          @map("organization_id")
  workflowId             String          @map("workflow_id")
  workflowVersionId      String?         @map("workflow_version_id")
  webhookEventId         String?         @map("webhook_event_id")
  scheduledTriggerId     String?         @map("scheduled_trigger_id")
  scheduledFor           DateTime?       @map("scheduled_for")
  correlationId          String?         @map("correlation_id")
  retryOfExecutionId     String?         @map("retry_of_execution_id")
  replayOfExecutionId    String?         @map("replay_of_execution_id")
  replayMode             ExecutionReplayMode? @map("replay_mode")
  replayFromStepKey      String?         @map("replay_from_step_key")
  replayFromExecutionPath String?        @map("replay_from_execution_path")
  replayFromIterationIndex Int?          @map("replay_from_iteration_index")
  parentExecutionId      String?         @map("parent_execution_id")
  parentStepExecutionId  String?         @map("parent_step_execution_id")
  rootExecutionId        String?         @map("root_execution_id")
  depth                  Int             @default(0)
  eventDeliveryId        String?         @unique @map("event_delivery_id")
  eventRootId            String?         @map("event_root_id")
  eventCausationId       String?         @map("event_causation_id")
  eventDepth             Int             @default(0) @map("event_depth")
  retryRequestedByUserId String?         @map("retry_requested_by_user_id")
  retryRequestedAt       DateTime?       @map("retry_requested_at")
  retryReason            String?         @map("retry_reason")
  startedByUserId        String?         @map("started_by_user_id")
  cancelRequestedByUserId String?        @map("cancel_requested_by_user_id")
  cancelRequestedAt      DateTime?       @map("cancel_requested_at")
  cancelledAt            DateTime?       @map("cancelled_at")
  cancelReason           String?         @map("cancel_reason")
  manualExecutionKey     String?         @map("manual_execution_key")
  status                 ExecutionStatus @default(PENDING)
  waitReason             String?         @map("wait_reason")
  executionMode          ExecutionMode   @default(REAL) @map("execution_mode")
  inputJson              Json            @map("input_json")
  contextJson            Json            @map("context_json")
  outputJson             Json?           @map("output_json")
  errorJson              Json?           @map("error_json")
  lockedBy               String?         @map("locked_by")
  lockedUntil            DateTime?       @map("locked_until")
  lastHeartbeatAt        DateTime?       @map("last_heartbeat_at")
  runAttempt             Int             @default(0) @map("run_attempt")
  startedAt              DateTime?       @map("started_at")
  completedAt            DateTime?       @map("completed_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow         Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion  WorkflowVersion?      @relation(fields: [workflowVersionId], references: [id], onDelete: SetNull)
  webhookEvent     WebhookEvent?         @relation(fields: [webhookEventId], references: [id])
  scheduledTrigger Trigger?              @relation("ScheduledTriggerExecutions", fields: [scheduledTriggerId], references: [id], onDelete: SetNull)
  retryOfExecution Execution?            @relation("ExecutionRetries", fields: [retryOfExecutionId], references: [id])
  retryExecutions  Execution[]           @relation("ExecutionRetries")
  replayOfExecution Execution?           @relation("ExecutionReplays", fields: [replayOfExecutionId], references: [id], onDelete: Restrict)
  replayExecutions  Execution[]           @relation("ExecutionReplays")
  parentExecution  Execution?            @relation("ExecutionChildren", fields: [parentExecutionId], references: [id], onDelete: SetNull)
  childExecutions  Execution[]           @relation("ExecutionChildren")
  rootExecution    Execution?            @relation("ExecutionRoot", fields: [rootExecutionId], references: [id], onDelete: SetNull)
  descendantExecutions Execution[]       @relation("ExecutionRoot")
  parentStepExecution StepExecution?     @relation("StepExecutionChildren", fields: [parentStepExecutionId], references: [id], onDelete: SetNull)
  retryRequestedBy User?                 @relation("ExecutionRetryRequestedBy", fields: [retryRequestedByUserId], references: [id])
  startedBy        User?                 @relation("ExecutionStartedBy", fields: [startedByUserId], references: [id])
  cancelRequestedBy User?                @relation("ExecutionCancelRequestedBy", fields: [cancelRequestedByUserId], references: [id])
  steps            StepExecution[]
  stepAttempts     StepExecutionAttempt[]
  internalRecords  InternalRecord[]
  deadLetters      DeadLetterExecution[] @relation("DeadLetterOriginalExecution")
  retryDeadLetters DeadLetterExecution[] @relation("DeadLetterRetryExecution")
  testRun          WorkflowTestRun?
  triggerLastFor   Trigger[]              @relation("TriggerLastExecution")
  approvalRequests ApprovalRequest[]
  eventDelivery    InternalEventDelivery? @relation("EventDeliveryExecution", fields: [eventDeliveryId], references: [id], onDelete: SetNull)
  recoveryStepReuses ExecutionStepReuse[] @relation("RecoveryExecutionStepReuses")
  sourceStepReuses   ExecutionStepReuse[] @relation("SourceExecutionStepReuses")

  @@index([organizationId, workflowId, status])
  @@index([organizationId, workflowId, executionMode, createdAt])
  @@index([organizationId, correlationId])
  @@index([organizationId, manualExecutionKey])
  @@index([organizationId, scheduledTriggerId, scheduledFor])
  @@index([status, lockedUntil])
  @@index([retryOfExecutionId, status])
  @@index([organizationId, replayOfExecutionId, createdAt])
  @@index([parentExecutionId])
  @@index([parentStepExecutionId])
  @@index([rootExecutionId])
  @@index([organizationId, eventRootId])
  @@map("executions")
}

model InternalEvent {
  id                  String              @id @default(uuid())
  organizationId      String              @map("organization_id")
  eventType           String              @map("event_type")
  schemaVersion       Int                 @default(1) @map("schema_version")
  envelopeJson        Json                @map("envelope_json")
  occurredAt          DateTime            @map("occurred_at")
  rootEventId         String              @map("root_event_id")
  causationId         String?             @map("causation_id")
  correlationId       String              @map("correlation_id")
  depth               Int                 @default(0)
  status              InternalEventStatus @default(PENDING)
  attempts            Int                 @default(0)
  nextAttemptAt       DateTime?           @map("next_attempt_at")
  lockedBy            String?             @map("locked_by")
  lockedUntil         DateTime?           @map("locked_until")
  matchingCompletedAt DateTime?           @map("matching_completed_at")
  processedAt         DateTime?           @map("processed_at")
  deadLetteredAt      DateTime?           @map("dead_lettered_at")
  lastErrorCode       String?             @map("last_error_code")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  organization Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries  InternalEventDelivery[]

  @@index([status, nextAttemptAt, lockedUntil, occurredAt])
  @@index([organizationId, eventType, occurredAt])
  @@index([organizationId, rootEventId])
  @@map("internal_events")
}

model InternalEventChain {
  rootEventId    String   @id @map("root_event_id")
  organizationId String  @map("organization_id")
  eventCount     Int      @default(1) @map("event_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, updatedAt])
  @@map("internal_event_chains")
}

model InternalEventDelivery {
  id              String                      @id @default(uuid())
  organizationId  String                      @map("organization_id")
  internalEventId String                      @map("internal_event_id")
  triggerId       String                      @map("trigger_id")
  executionId     String?                     @unique @map("execution_id")
  status          InternalEventDeliveryStatus @default(PENDING)
  attempts        Int                         @default(0)
  lastErrorCode   String?                     @map("last_error_code")
  materializedAt  DateTime?                   @map("materialized_at")
  enqueuedAt      DateTime?                   @map("enqueued_at")
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  internalEvent InternalEvent @relation(fields: [internalEventId], references: [id], onDelete: Cascade)
  trigger       Trigger       @relation(fields: [triggerId], references: [id], onDelete: Cascade)
  execution     Execution?    @relation("EventDeliveryExecution")

  @@unique([internalEventId, triggerId])
  @@index([organizationId, status, createdAt])
  @@map("internal_event_deliveries")
}

model StepExecution {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  executionId    String              @map("execution_id")
  workflowStepId String?             @map("workflow_step_id")
  stepKey        String              @map("step_key")
  stepType       String              @map("step_type")
  status         StepExecutionStatus @default(PENDING)
  attempt        Int                 @default(1)
  attemptCount   Int                 @default(0) @map("attempt_count")
  maxAttempts    Int                 @default(1) @map("max_attempts")
  nextRetryAt    DateTime?           @map("next_retry_at")
  effectKey      String?             @map("effect_key")
  effectStatus   String?             @map("effect_status")
  workerId       String?             @map("worker_id")
  inputJson      Json                @map("input_json")
  outputJson     Json?               @map("output_json")
  errorJson      Json?               @map("error_json")
  debugJson      Json?               @map("debug_json")
  executionPath  String              @default("root") @map("execution_path")
  iterationIndex Int?                @map("iteration_index")
  errorHandled   Boolean             @default(false) @map("error_handled")
  startedAt      DateTime?           @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  durationMs     Int?                @map("duration_ms")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution       Execution             @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflowStep    WorkflowStep?         @relation(fields: [workflowStepId], references: [id], onDelete: SetNull)
  internalRecords InternalRecord[]
  deadLetters     DeadLetterExecution[] @relation("DeadLetterFailedStep")
  childExecutions Execution[]           @relation("StepExecutionChildren")
  approvalRequest ApprovalRequest?
  attempts        StepExecutionAttempt[]
  sourceReuses    ExecutionStepReuse[]

  @@unique([executionId, stepKey, executionPath])
  @@index([organizationId, executionId])
  @@map("step_executions")
}

model ExecutionStepReuse {
  id                    String              @id @default(uuid())
  organizationId        String              @map("organization_id")
  recoveryExecutionId   String              @map("recovery_execution_id")
  sourceExecutionId     String              @map("source_execution_id")
  sourceStepExecutionId String              @map("source_step_execution_id")
  stepKey               String              @map("step_key")
  stepType              String              @map("step_type")
  executionPath         String              @default("root") @map("execution_path")
  iterationIndex        Int?                @map("iteration_index")
  status                StepExecutionStatus
  createdAt             DateTime            @default(now()) @map("created_at")

  organization          Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  recoveryExecution     Execution           @relation("RecoveryExecutionStepReuses", fields: [recoveryExecutionId], references: [id], onDelete: Cascade)
  sourceExecution       Execution           @relation("SourceExecutionStepReuses", fields: [sourceExecutionId], references: [id], onDelete: Restrict)
  sourceStepExecution   StepExecution       @relation(fields: [sourceStepExecutionId], references: [id], onDelete: Restrict)

  @@unique([recoveryExecutionId, stepKey, executionPath])
  @@index([organizationId, recoveryExecutionId])
  @@index([sourceExecutionId])
  @@map("execution_step_reuses")
}

model StepExecutionAttempt {
  id              String              @id @default(uuid())
  organizationId  String              @map("organization_id")
  executionId     String              @map("execution_id")
  stepExecutionId String              @map("step_execution_id")
  attempt         Int
  status          StepExecutionStatus
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  durationMs      Int?                @map("duration_ms")
  nextRetryAt     DateTime?           @map("next_retry_at")
  waitReason      String?             @map("wait_reason")
  effectStatus    String?             @map("effect_status")
  errorCategory   String?             @map("error_category")
  errorCodeSafe   String?             @map("error_code_safe")
  errorMessageSafe String?            @map("error_message_safe")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution    Execution    @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution StepExecution @relation(fields: [stepExecutionId], references: [id], onDelete: Cascade)

  @@unique([stepExecutionId, attempt])
  @@index([organizationId, executionId, startedAt, id])
  @@map("step_execution_attempts")
}

model ApprovalRequest {
  id                  String           @id @default(uuid())
  organizationId      String           @map("organization_id")
  executionId         String           @map("execution_id")
  stepExecutionId     String           @unique @map("step_execution_id")
  workflowId          String           @map("workflow_id")
  workflowVersionId   String?          @map("workflow_version_id")
  stepKey             String           @map("step_key")
  executionPath       String           @default("root") @map("execution_path")
  iterationIndex      Int?             @map("iteration_index")
  status              ApprovalStatus   @default(PENDING)
  title               String
  description         String?
  summary             String?
  assigneePolicy      String           @default("ANY_AUTHORIZED_USER") @map("assignee_policy")
  allowedRoles        String[]         @map("allowed_roles")
  requestedAt         DateTime         @default(now()) @map("requested_at")
  expiresAt           DateTime?        @map("expires_at")
  decidedAt           DateTime?        @map("decided_at")
  decidedByUserId     String?          @map("decided_by_user_id")
  decision            ApprovalDecision?
  decisionComment     String?          @map("decision_comment")
  version             Int              @default(0)
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  organization        Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution           Execution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution       StepExecution    @relation(fields: [stepExecutionId], references: [id], onDelete: Cascade)
  workflow            Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion     WorkflowVersion? @relation(fields: [workflowVersionId], references: [id], onDelete: SetNull)
  decidedBy           User?            @relation(fields: [decidedByUserId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, requestedAt])
  @@index([executionId])
  @@index([status, expiresAt])
  @@index([organizationId, workflowId, requestedAt])
  @@index([decidedByUserId])
  @@map("approval_requests")
}

model WorkflowTestRun {
  id                String           @id @default(uuid())
  organizationId    String           @map("organization_id")
  workflowId        String           @map("workflow_id")
  workflowVersionId String?          @map("workflow_version_id")
  executionId       String           @unique @map("execution_id")
  createdByUserId   String           @map("created_by_user_id")
  externalMode      TestExternalMode @default(mock) @map("external_mode")
  displayName       String?          @map("display_name")
  payloadJson       Json             @map("payload_json")
  stepMocksJson     Json             @map("step_mocks_json")
  snapshotDefinitionJson Json         @map("snapshot_definition_json")
  draftDefinitionJson Json?          @map("draft_definition_json")
  source             String           @default("version")
  realModeConfirmedAt DateTime?       @map("real_mode_confirmed_at")
  realModeConfirmedByUserId String?   @map("real_mode_confirmed_by_user_id")
  compareWithLastReal Boolean        @default(false) @map("compare_with_last_real")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow        Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion? @relation(fields: [workflowVersionId], references: [id], onDelete: SetNull)
  execution       Execution       @relation(fields: [executionId], references: [id], onDelete: Cascade)
  createdBy       User            @relation("WorkflowTestRunCreatedBy", fields: [createdByUserId], references: [id])

  @@index([organizationId, workflowId, createdAt])
  @@index([organizationId, executionId])
  @@index([organizationId, workflowVersionId])
  @@map("workflow_test_runs")
}

model WebhookEvent {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  workflowId         String   @map("workflow_id")
  triggerId          String   @map("trigger_id")
  idempotencyKey     String?  @map("idempotency_key")
  requestId          String?  @map("request_id")
  correlationId      String?  @map("correlation_id")
  method             String   @default("POST")
  queryJson          Json     @default("{}") @map("query_json")
  requestHeadersJson Json     @map("request_headers_json")
  payloadJson        Json     @map("payload_json")
  payloadHash        String   @map("payload_hash")
  sourceIp           String?  @map("source_ip")
  receivedAt         DateTime @default(now()) @map("received_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger      Trigger      @relation(fields: [triggerId], references: [id])
  executions   Execution[]

  @@index([organizationId, workflowId, receivedAt])
  @@index([organizationId, correlationId])
  @@map("webhook_events")
}

model WebhookReplayNonce {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  triggerId      String   @map("trigger_id")
  nonce          String
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger      Trigger      @relation(fields: [triggerId], references: [id], onDelete: Cascade)

  @@unique([organizationId, triggerId, nonce])
  @@index([expiresAt])
  @@map("webhook_replay_nonces")
}

model IdempotencyKey {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  scope          String
  key            String
  requestHash    String            @map("request_hash")
  status         IdempotencyStatus @default(STARTED)
  responseJson   Json?             @map("response_json")
  lockedUntil    DateTime?         @map("locked_until")
  expiresAt      DateTime          @map("expires_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model Connection {
  id              String           @id @default(uuid())
  organizationId  String           @map("organization_id")
  name            String
  description     String?
  type            ConnectionType
  configJson      Json             @map("config_json")
  status          ConnectionStatus @default(ACTIVE)
  createdByUserId String           @map("created_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rotatedAt       DateTime?        @map("rotated_at")
  revokedAt       DateTime?        @map("revoked_at")
  deletedAt       DateTime?        @map("deleted_at")
  lastTestedAt    DateTime?        @map("last_tested_at")
  lastTestStatus  String?          @map("last_test_status")
  lastTestStatusCode Int?          @map("last_test_status_code")
  lastTestDurationMs Int?          @map("last_test_duration_ms")
  lastTestMessage String?          @map("last_test_message")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secrets      Secret[]
  notificationRules NotificationRule[]

  @@index([organizationId, type])
  @@index([organizationId, type, status])
  @@index([organizationId, deletedAt])
  @@map("connections")
}

model NotificationRule {
  id                  String              @id @default(uuid())
  organizationId      String              @map("organization_id")
  eventType           String              @map("event_type")
  channel             NotificationChannel @default(EMAIL)
  enabled             Boolean             @default(true)
  connectionId        String              @map("connection_id")
  recipientConfigJson Json                @map("recipient_config_json")
  filtersJson         Json                @default("{}") @map("filters_json")
  templateKey         String              @map("template_key")
  deletedAt           DateTime?           @map("deleted_at")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   Connection            @relation(fields: [connectionId], references: [id], onDelete: Restrict)
  requests     NotificationRequest[]

  @@index([organizationId, enabled, eventType, deletedAt])
  @@index([organizationId, connectionId])
  @@map("notification_rules")
}

model NotificationRequest {
  id                 String              @id @default(uuid())
  organizationId     String              @map("organization_id")
  notificationRuleId String              @map("notification_rule_id")
  sourceEventId      String              @map("source_event_id")
  type               String
  channel            NotificationChannel @default(EMAIL)
  status             NotificationStatus  @default(PENDING)
  recipient          String
  subject            String
  templateKey        String              @map("template_key")
  payloadJson        Json                @map("payload_json")
  idempotencyKey     String              @map("idempotency_key")
  correlationId      String?             @map("correlation_id")
  scheduledAt        DateTime            @default(now()) @map("scheduled_at")
  nextAttemptAt      DateTime?           @map("next_attempt_at")
  lockedBy           String?             @map("locked_by")
  lockedUntil        DateTime?           @map("locked_until")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  organization Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rule         NotificationRule     @relation(fields: [notificationRuleId], references: [id], onDelete: Restrict)
  delivery     NotificationDelivery?

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, status, createdAt])
  @@index([status, scheduledAt, nextAttemptAt, lockedUntil])
  @@index([sourceEventId])
  @@map("notification_requests")
}

model NotificationDelivery {
  id                    String                     @id @default(uuid())
  organizationId        String                     @map("organization_id")
  notificationRequestId String                     @unique @map("notification_request_id")
  provider              String                     @default("smtp")
  status                NotificationStatus         @default(PENDING)
  attempts              Int                        @default(0)
  lastAttemptAt         DateTime?                   @map("last_attempt_at")
  sentAt                DateTime?                   @map("sent_at")
  failedAt              DateTime?                   @map("failed_at")
  providerMessageId     String?                     @map("provider_message_id")
  errorCategory         NotificationErrorCategory? @map("error_category")
  errorMessageSafe      String?                     @map("error_message_safe")
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  request      NotificationRequest @relation(fields: [notificationRequestId], references: [id], onDelete: Cascade)

  @@index([organizationId, status, createdAt])
  @@map("notification_deliveries")
}

model Secret {
  id                   String    @id @default(uuid())
  organizationId       String    @map("organization_id")
  connectionId         String    @map("connection_id")
  name                 String
  encryptedValue       String    @map("encrypted_value")
  encryptionVersion    Int       @default(1) @map("encryption_version")
  keyId                String?   @map("key_id")
  status               SecretStatus @default(ACTIVE)
  createdAt            DateTime  @default(now()) @map("created_at")
  rotatedAt            DateTime? @map("rotated_at")
  revokedAt            DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId, connectionId])
  @@map("secrets")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  correlationId  String?  @map("correlation_id")
  metadataJson   Json     @map("metadata_json")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, correlationId])
  @@map("audit_logs")
}

model InternalRecord {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  workflowId        String   @map("workflow_id")
  workflowVersionId String?  @map("workflow_version_id")
  executionId       String   @map("execution_id")
  stepExecutionId   String   @map("step_execution_id")
  collection        String
  dedupeKey         String   @map("dedupe_key")
  dataJson          Json     @map("data_json")
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow        Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion? @relation(fields: [workflowVersionId], references: [id])
  execution       Execution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution   StepExecution    @relation(fields: [stepExecutionId], references: [id])

  @@unique([organizationId, executionId, collection, dedupeKey])
  @@index([organizationId, collection, createdAt])
