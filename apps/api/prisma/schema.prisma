}

model DataStore {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  name           String
  description    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  records      DataStoreRecord[]

  @@index([organizationId, deletedAt, updatedAt])
  @@map("data_stores")
}

model DataStoreRecord {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  dataStoreId    String    @map("data_store_id")
  key            String
  valueJson      Json      @map("value_json")
  metadataJson   Json      @default("{}") @map("metadata_json")
  expiresAt      DateTime? @map("expires_at")
  version        Int       @default(1)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  dataStore    DataStore    @relation(fields: [dataStoreId], references: [id], onDelete: Cascade)

  @@index([organizationId, dataStoreId, deletedAt, key])
  @@index([dataStoreId, expiresAt, deletedAt])
  @@map("data_store_records")
}

model DeadLetterExecution {
  id                    String    @id @default(uuid())
  organizationId        String    @map("organization_id")
  executionId           String    @map("execution_id")
  workflowId            String    @map("workflow_id")
  workflowVersionId     String    @map("workflow_version_id")
  sourceQueue           String    @map("source_queue")
  reason                String
  failedStepKey         String?   @map("failed_step_key")
  failedStepExecutionId String?   @map("failed_step_execution_id")
  attempts              Int       @default(0)
  lastErrorJson         Json?     @map("last_error_json")
  jobId                 String?   @map("job_id")
  retryExecutionId      String?   @map("retry_execution_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  resolvedAt            DateTime? @map("resolved_at")
  resolution            String?

  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution           Execution       @relation("DeadLetterOriginalExecution", fields: [executionId], references: [id], onDelete: Cascade)
  workflow            Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion     WorkflowVersion @relation(fields: [workflowVersionId], references: [id])
  failedStepExecution StepExecution?  @relation("DeadLetterFailedStep", fields: [failedStepExecutionId], references: [id])
  retryExecution      Execution?      @relation("DeadLetterRetryExecution", fields: [retryExecutionId], references: [id])

  @@index([organizationId])
  @@index([executionId])
  @@index([createdAt])
  @@index([resolvedAt])
  @@map("dead_letter_executions")
}

model OrganizationVariable {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  key            String
  valueJson      Json     @map("value_json")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("organization_variables")
}

model WorkflowVariable {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  workflowId     String   @map("workflow_id")
  key            String
  valueJson      Json     @map("value_json")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow     Workflow     @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, key])
  @@index([organizationId, workflowId])
  @@map("workflow_variables")
}
