generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum OrganizationRole {
  owner
  admin
  editor
  viewer
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ExecutionStatus {
  PENDING
  QUEUED
  RUNNING
  RETRYING
  COMPLETED
  FAILED
  CANCELLED
}

enum StepExecutionStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
  RETRYING
}

enum IdempotencyStatus {
  STARTED
  PROCESSING
  ENQUEUED
  COMPLETED
  FAILED
}

enum ConnectionType {
  smtp
  http_api_key
  oauth_future
}

enum ConnectionStatus {
  ACTIVE
  DISABLED
  REVOKED
  DELETED
}

enum SecretStatus {
  ACTIVE
  REVOKED
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String     @map("password_hash")
  name         String
  status       UserStatus @default(ACTIVE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  memberships               OrganizationMember[]
  workflows                 Workflow[]            @relation("WorkflowCreatedBy")
  versions                  WorkflowVersion[]     @relation("WorkflowVersionCreatedBy")
  sessions                  RefreshTokenSession[]
  requestedExecutionRetries Execution[]           @relation("ExecutionRetryRequestedBy")

  @@map("users")
}

model RefreshTokenSession {
  id                  String    @id @default(uuid())
  userId              String    @map("user_id")
  tokenHash           String    @map("token_hash")
  tokenFamily         String    @map("token_family")
  revokedAt           DateTime? @map("revoked_at")
  replacedBySessionId String?   @unique @map("replaced_by_session_id")
  expiresAt           DateTime  @map("expires_at")
  lastUsedAt          DateTime  @default(now()) @map("last_used_at")
  userAgent           String?   @map("user_agent")
  ipHash              String?   @map("ip_hash")
  createdAt           DateTime  @default(now()) @map("created_at")

  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedBySession RefreshTokenSession?  @relation("RefreshTokenSessionReplacement", fields: [replacedBySessionId], references: [id])
  replacesSessions  RefreshTokenSession[] @relation("RefreshTokenSessionReplacement")

  @@index([userId])
  @@index([tokenFamily])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_token_sessions")
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members              OrganizationMember[]
  workflows            Workflow[]
  workflowVersions     WorkflowVersion[]
  workflowSteps        WorkflowStep[]
  triggers             Trigger[]
  executions           Execution[]
  stepExecutions       StepExecution[]
  deadLetterExecutions DeadLetterExecution[]
  connections          Connection[]
  secrets              Secret[]
  webhookEvents        WebhookEvent[]
  auditLogs            AuditLog[]
  idempotencyKeys      IdempotencyKey[]
  internalRecords      InternalRecord[]

  @@map("organizations")
}

model OrganizationMember {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  role           OrganizationRole
  status         MemberStatus     @default(ACTIVE)
  createdAt      DateTime         @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Workflow {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  name            String
  description     String?
  status          WorkflowStatus @default(DRAFT)
  activeVersionId String?        @unique @map("active_version_id")
  createdByUserId String         @map("created_by_user_id")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy            User                  @relation("WorkflowCreatedBy", fields: [createdByUserId], references: [id])
  versions             WorkflowVersion[]     @relation("WorkflowVersions")
  activeVersion        WorkflowVersion?      @relation("ActiveWorkflowVersion", fields: [activeVersionId], references: [id])
  triggers             Trigger[]
  executions           Execution[]
  internalRecords      InternalRecord[]
  deadLetterExecutions DeadLetterExecution[]

  @@index([organizationId, status])
  @@map("workflows")
}

model WorkflowVersion {
  id              String                @id @default(uuid())
  organizationId  String                @map("organization_id")
  workflowId      String                @map("workflow_id")
  versionNumber   Int                   @map("version_number")
  status          WorkflowVersionStatus @default(DRAFT)
  definitionJson  Json                  @map("definition_json")
  createdByUserId String                @map("created_by_user_id")
  createdAt       DateTime              @default(now()) @map("created_at")
  activatedAt     DateTime?             @map("activated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow             Workflow              @relation("WorkflowVersions", fields: [workflowId], references: [id], onDelete: Cascade)
  activeForWorkflow    Workflow?             @relation("ActiveWorkflowVersion")
  createdBy            User                  @relation("WorkflowVersionCreatedBy", fields: [createdByUserId], references: [id])
  steps                WorkflowStep[]
  executions           Execution[]
  internalRecords      InternalRecord[]
  deadLetterExecutions DeadLetterExecution[]

  @@unique([workflowId, versionNumber])
  @@index([organizationId, workflowId])
  @@map("workflow_versions")
}

model WorkflowStep {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  workflowVersionId String   @map("workflow_version_id")
  key               String
  name              String
  type              String
  position          Int
  configJson        Json     @map("config_json")
  retryPolicyJson   Json?    @map("retry_policy_json")
  timeoutSeconds    Int?     @map("timeout_seconds")
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion @relation(fields: [workflowVersionId], references: [id], onDelete: Cascade)
  stepExecutions  StepExecution[]

  @@unique([workflowVersionId, key])
  @@index([organizationId, workflowVersionId])
  @@map("workflow_steps")
}

model Trigger {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  workflowId     String    @map("workflow_id")
  type           String
  tokenHash      String    @map("token_hash")
  configJson     Json      @map("config_json")
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  rotatedAt      DateTime? @map("rotated_at")

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow      Workflow       @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  webhookEvents WebhookEvent[]

  @@index([workflowId, enabled])
  @@map("triggers")
}

model Execution {
  id                     String          @id @default(uuid())
  organizationId         String          @map("organization_id")
  workflowId             String          @map("workflow_id")
  workflowVersionId      String          @map("workflow_version_id")
  webhookEventId         String?         @map("webhook_event_id")
  correlationId          String?         @map("correlation_id")
  retryOfExecutionId     String?         @map("retry_of_execution_id")
  retryRequestedByUserId String?         @map("retry_requested_by_user_id")
  retryRequestedAt       DateTime?       @map("retry_requested_at")
  retryReason            String?         @map("retry_reason")
  status                 ExecutionStatus @default(PENDING)
  inputJson              Json            @map("input_json")
  contextJson            Json            @map("context_json")
  errorJson              Json?           @map("error_json")
  lockedBy               String?         @map("locked_by")
  lockedUntil            DateTime?       @map("locked_until")
  lastHeartbeatAt        DateTime?       @map("last_heartbeat_at")
  runAttempt             Int             @default(0) @map("run_attempt")
  startedAt              DateTime?       @map("started_at")
  completedAt            DateTime?       @map("completed_at")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  organization     Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow         Workflow              @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion  WorkflowVersion       @relation(fields: [workflowVersionId], references: [id])
  webhookEvent     WebhookEvent?         @relation(fields: [webhookEventId], references: [id])
  retryOfExecution Execution?            @relation("ExecutionRetries", fields: [retryOfExecutionId], references: [id])
  retryExecutions  Execution[]           @relation("ExecutionRetries")
  retryRequestedBy User?                 @relation("ExecutionRetryRequestedBy", fields: [retryRequestedByUserId], references: [id])
  steps            StepExecution[]
  internalRecords  InternalRecord[]
  deadLetters      DeadLetterExecution[] @relation("DeadLetterOriginalExecution")
  retryDeadLetters DeadLetterExecution[] @relation("DeadLetterRetryExecution")

  @@index([organizationId, workflowId, status])
  @@index([organizationId, correlationId])
  @@index([status, lockedUntil])
  @@index([retryOfExecutionId, status])
  @@map("executions")
}

model StepExecution {
  id             String              @id @default(uuid())
  organizationId String              @map("organization_id")
  executionId    String              @map("execution_id")
  workflowStepId String              @map("workflow_step_id")
  stepKey        String              @map("step_key")
  stepType       String              @map("step_type")
  status         StepExecutionStatus @default(PENDING)
  attempt        Int                 @default(1)
  attemptCount   Int                 @default(0) @map("attempt_count")
  maxAttempts    Int                 @default(1) @map("max_attempts")
  nextRetryAt    DateTime?           @map("next_retry_at")
  effectKey      String?             @map("effect_key")
  effectStatus   String?             @map("effect_status")
  workerId       String?             @map("worker_id")
  inputJson      Json                @map("input_json")
  outputJson     Json?               @map("output_json")
  errorJson      Json?               @map("error_json")
  startedAt      DateTime?           @map("started_at")
  completedAt    DateTime?           @map("completed_at")
  durationMs     Int?                @map("duration_ms")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  organization    Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution       Execution             @relation(fields: [executionId], references: [id], onDelete: Cascade)
  workflowStep    WorkflowStep          @relation(fields: [workflowStepId], references: [id])
  internalRecords InternalRecord[]
  deadLetters     DeadLetterExecution[] @relation("DeadLetterFailedStep")

  @@unique([executionId, workflowStepId])
  @@index([organizationId, executionId])
  @@map("step_executions")
}

model WebhookEvent {
  id                 String   @id @default(uuid())
  organizationId     String   @map("organization_id")
  workflowId         String   @map("workflow_id")
  triggerId          String   @map("trigger_id")
  idempotencyKey     String?  @map("idempotency_key")
  requestId          String?  @map("request_id")
  correlationId      String?  @map("correlation_id")
  requestHeadersJson Json     @map("request_headers_json")
  payloadJson        Json     @map("payload_json")
  payloadHash        String   @map("payload_hash")
  sourceIp           String?  @map("source_ip")
  receivedAt         DateTime @default(now()) @map("received_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trigger      Trigger      @relation(fields: [triggerId], references: [id])
  executions   Execution[]

  @@index([organizationId, workflowId, receivedAt])
  @@index([organizationId, correlationId])
  @@map("webhook_events")
}

model IdempotencyKey {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  scope          String
  key            String
  requestHash    String            @map("request_hash")
  status         IdempotencyStatus @default(STARTED)
  responseJson   Json?             @map("response_json")
  lockedUntil    DateTime?         @map("locked_until")
  expiresAt      DateTime          @map("expires_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, scope, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model Connection {
  id              String           @id @default(uuid())
  organizationId  String           @map("organization_id")
  name            String
  description     String?
  type            ConnectionType
  configJson      Json             @map("config_json")
  status          ConnectionStatus @default(ACTIVE)
  createdByUserId String           @map("created_by_user_id")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  rotatedAt       DateTime?        @map("rotated_at")
  revokedAt       DateTime?        @map("revoked_at")
  deletedAt       DateTime?        @map("deleted_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  secrets      Secret[]

  @@index([organizationId, type])
  @@index([organizationId, type, status])
  @@index([organizationId, deletedAt])
  @@map("connections")
}

model Secret {
  id                   String    @id @default(uuid())
  organizationId       String    @map("organization_id")
  connectionId         String    @map("connection_id")
  name                 String
  encryptedValue       String    @map("encrypted_value")
  encryptionVersion    Int       @default(1) @map("encryption_version")
  keyId                String?   @map("key_id")
  status               SecretStatus @default(ACTIVE)
  createdAt            DateTime  @default(now()) @map("created_at")
  rotatedAt            DateTime? @map("rotated_at")
  revokedAt            DateTime? @map("revoked_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection   Connection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([organizationId, connectionId])
  @@map("secrets")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  actorUserId    String?  @map("actor_user_id")
  action         String
  resourceType   String   @map("resource_type")
  resourceId     String   @map("resource_id")
  correlationId  String?  @map("correlation_id")
  metadataJson   Json     @map("metadata_json")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([organizationId, correlationId])
  @@map("audit_logs")
}

model InternalRecord {
  id                String   @id @default(uuid())
  organizationId    String   @map("organization_id")
  workflowId        String   @map("workflow_id")
  workflowVersionId String?  @map("workflow_version_id")
  executionId       String   @map("execution_id")
  stepExecutionId   String   @map("step_execution_id")
  collection        String
  dedupeKey         String   @map("dedupe_key")
  dataJson          Json     @map("data_json")
  createdAt         DateTime @default(now()) @map("created_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow        Workflow         @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion WorkflowVersion? @relation(fields: [workflowVersionId], references: [id])
  execution       Execution        @relation(fields: [executionId], references: [id], onDelete: Cascade)
  stepExecution   StepExecution    @relation(fields: [stepExecutionId], references: [id])

  @@unique([organizationId, executionId, collection, dedupeKey])
  @@index([organizationId, collection, createdAt])
  @@map("internal_records")
}

model DeadLetterExecution {
  id                    String    @id @default(uuid())
  organizationId        String    @map("organization_id")
  executionId           String    @map("execution_id")
  workflowId            String    @map("workflow_id")
  workflowVersionId     String    @map("workflow_version_id")
  sourceQueue           String    @map("source_queue")
  reason                String
  failedStepKey         String?   @map("failed_step_key")
  failedStepExecutionId String?   @map("failed_step_execution_id")
  attempts              Int       @default(0)
  lastErrorJson         Json?     @map("last_error_json")
  jobId                 String?   @map("job_id")
  retryExecutionId      String?   @map("retry_execution_id")
  createdAt             DateTime  @default(now()) @map("created_at")
  resolvedAt            DateTime? @map("resolved_at")
  resolution            String?

  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  execution           Execution       @relation("DeadLetterOriginalExecution", fields: [executionId], references: [id], onDelete: Cascade)
  workflow            Workflow        @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  workflowVersion     WorkflowVersion @relation(fields: [workflowVersionId], references: [id])
  failedStepExecution StepExecution?  @relation("DeadLetterFailedStep", fields: [failedStepExecutionId], references: [id])
  retryExecution      Execution?      @relation("DeadLetterRetryExecution", fields: [retryExecutionId], references: [id])

  @@index([organizationId])
  @@index([executionId])
  @@index([createdAt])
  @@index([resolvedAt])
  @@map("dead_letter_executions")
}
