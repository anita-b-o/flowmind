NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automation_platform
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SAME_SITE=lax
# REFRESH_COOKIE_DOMAIN=
SESSION_IP_HASH_PEPPER=change-me-session-ip-pepper
CORS_ORIGIN=http://localhost:3000
# AUTH_ORIGIN_REQUIRED=true
SECRET_ENCRYPTION_KEY=change-me-32-byte-development-key
# CONNECTION_ENCRYPTION_KEY=base64:replace-with-openssl-rand-base64-32
CONNECTION_ENCRYPTION_VERSION=1
CONNECTION_TEST_TIMEOUT_MS=5000
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=dev-ai-service-key
LLM_PROVIDER=fake
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_TIMEOUT_MS=30000
OPENAI_MAX_RETRIES=2
OPENAI_TEMPERATURE=0.2
OPENAI_MAX_OUTPUT_TOKENS=1000
PUBLIC_API_URL=http://localhost:3001
WEBHOOK_TOKEN_PEPPER=change-me-webhook-token-pepper
NEXT_PUBLIC_API_URL=http://localhost:3001
MAIL_HOST=localhost
MAIL_PORT=1025
WEBHOOK_PAYLOAD_MAX_BYTES=1048576
WEBHOOK_PAYLOAD_MAX_DEPTH=8
WEBHOOK_PAYLOAD_MAX_KEYS=1000
WEBHOOK_PAYLOAD_MAX_ARRAY_LENGTH=200
WEBHOOK_PAYLOAD_MAX_STRING_LENGTH=16384
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_BURST_LIMIT_MAX=10
SCHEDULED_TRIGGER_MIN_INTERVAL_SECONDS=60
EXECUTION_LEASE_DURATION_MS=60000
EXECUTION_HEARTBEAT_INTERVAL_MS=15000
EXECUTION_RECONCILIATION_INTERVAL_MS=10000
WORKER_SHUTDOWN_TIMEOUT_MS=30000
# Workflow debugger test runs use the same queue/lease settings.
# Mock mode prevents external side effects; real mode requires admin/owner confirmation and keeps database steps dry-run.
WORKER_HEALTH_PORT=3002
METRICS_ENABLED=false
METRICS_API_KEY=
METRICS_HOST=127.0.0.1
API_METRICS_PORT=9464
WORKER_METRICS_PORT=9465
AI_METRICS_PORT=9466
LOG_LEVEL=info
# LOG_FORMAT=pretty
LOG_REDACT_ENABLED=true
MAX_LOG_PAYLOAD_BYTES=16384
REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id
