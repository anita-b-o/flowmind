NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automation_platform
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_SAME_SITE=lax
# REFRESH_COOKIE_DOMAIN=
SESSION_IP_HASH_PEPPER=change-me-session-ip-pepper
CORS_ORIGIN=http://localhost:3000
# AUTH_ORIGIN_REQUIRED=true
SECRET_ENCRYPTION_KEY=change-me-32-byte-development-key
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=dev-ai-service-key
PUBLIC_API_URL=http://localhost:3001
WEBHOOK_TOKEN_PEPPER=change-me-webhook-token-pepper
NEXT_PUBLIC_API_URL=http://localhost:3001
MAIL_HOST=localhost
MAIL_PORT=1025
WEBHOOK_PAYLOAD_MAX_BYTES=1048576
WEBHOOK_RATE_LIMIT_WINDOW_SECONDS=60
WEBHOOK_RATE_LIMIT_MAX=60
WEBHOOK_BURST_LIMIT_MAX=10
EXECUTION_LEASE_DURATION_MS=60000
EXECUTION_HEARTBEAT_INTERVAL_MS=15000
EXECUTION_RECONCILIATION_INTERVAL_MS=10000
WORKER_SHUTDOWN_TIMEOUT_MS=30000
WORKER_HEALTH_PORT=3002
LOG_LEVEL=info
# LOG_FORMAT=pretty
LOG_REDACT_ENABLED=true
MAX_LOG_PAYLOAD_BYTES=16384
REQUEST_ID_HEADER=x-request-id
CORRELATION_ID_HEADER=x-correlation-id
